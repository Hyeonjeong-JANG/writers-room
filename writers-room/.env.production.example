# ============================================
# Writer's Room — Production Environment
# ============================================
# 이 파일을 .env.production.local로 복사하여 사용하세요.
# Vercel에서는 Settings > Environment Variables에 등록합니다.

# ---- Supabase (Production) ----
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ---- FLock API ----
FLOCK_API_KEY=your-flock-api-key
FLOCK_API_BASE_URL=https://api.flock.io/v1
FLOCK_DEFAULT_MODEL=your-default-model

# ---- Selanet ----
SELANET_API_KEY=your-selanet-key
SELANET_API_BASE_URL=https://api.selanet.com

# ---- Nansen (x402 pay-per-call) ----
NANSEN_API_BASE_URL=https://api.nansen.ai
NANSEN_X402_WALLET_KEY=your-nansen-wallet-key

# ---- Base / Blockchain (Mainnet) ----
NEXT_PUBLIC_BASE_CHAIN_ID=8453
NEXT_PUBLIC_USDC_CONTRACT=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913
NEXT_PUBLIC_CONTRIBUTION_CONTRACT=your-contribution-contract-address
NEXT_PUBLIC_REPUTATION_CONTRACT=your-reputation-contract-address

# ---- Coinbase ----
NEXT_PUBLIC_COINBASE_PROJECT_ID=your-coinbase-project-id

# ---- Site ----
NEXT_PUBLIC_SITE_URL=https://writersroom.xyz
